# Copy to .env.local and fill in values locally.
# .env.local is gitignored — do not commit real keys.
#
# Load before starting the proxy:
#   set -a && source .env.local && set +a
#   ./droid-proxy start --config config.yaml
#
# Or let start/service install pick up .env.local automatically.

# --- API key providers (set only what you use) ---

export DEEPSEEK_API_KEY=""
export OPENAI_API_KEY=""
export ANTHROPIC_API_KEY=""
export XAI_API_KEY=""
export MOONSHOT_API_KEY=""
export GROQ_API_KEY=""
export FIREWORKS_API_KEY=""
export FIREWORKS_FIRE_PASS_API_KEY=""   # Fire Pass (experimental, separate credential)

# Z.AI — use the env var that matches your known_auth profile:
export ZAI_API_KEY=""              # legacy alias for main API (known_auth: zai)
export ZAI_MAIN_API_KEY=""         # normal Z.AI API (known_auth: zai-main-api)
export ZAI_CODING_API_KEY=""       # GLM Coding Plan (known_auth: zai-coding-api)

# Xiaomi MiMo — standard API:
export MIMO_API_KEY=""

# MiMo Token Plan (pick one region):
export MIMO_TOKEN_PLAN_CN_API_KEY=""
export MIMO_TOKEN_PLAN_SGP_API_KEY=""
export MIMO_TOKEN_PLAN_AMS_API_KEY=""

# Local vLLM when started with --api-key:
# export VLLM_API_KEY=""

# --- Optional proxy client auth (only if client_auth.enabled: true) ---
# export DROID_PROXY_API_KEY=""

# OAuth (Codex/xAI) does not use env vars — run:
#   ./droid-proxy auth codex --config config.yaml
#   ./droid-proxy auth xai --config config.yaml
