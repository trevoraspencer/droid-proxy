export DEEPSEEK_API_KEY=""
export ZAI_CODING_API_KEY=""
export FIREWORKS_API_KEY=""
export FIREWORKS_MODEL="accounts/fireworks/models/deepseek-v4-pro"

# Optional normal Z.AI API values for configs that use known_auth: zai-main-api.
export ZAI_MAIN_API_KEY=""

# Legacy normal Z.AI API value for configs that still use known_auth: zai.
export ZAI_API_KEY=""

# Normal MiMo API access:
export MIMO_API_KEY=""
export MIMO_KNOWN_AUTH="mimo"
export MIMO_MODEL="mimo-v2.5-pro"

# MiMo Token Plan alternatives. Use exactly one region and set MIMO_KNOWN_AUTH
# to the matching known_auth value:
#   mimo-token-plan-cn
#   mimo-token-plan-sgp
#   mimo-token-plan-ams
export MIMO_TOKEN_PLAN_CN_API_KEY=""
export MIMO_TOKEN_PLAN_SGP_API_KEY=""
export MIMO_TOKEN_PLAN_AMS_API_KEY=""

# Optional provider model overrides after checking current account availability.
# The GPT-5.6 Sol aliases intentionally have no model override: their
# upstream_model is fixed to gpt-5.6-sol. CODEX_UPSTREAM_MODEL belonged to the
# previous GPT-5.2 scaffold and is ignored.
# Opt in only with credentials/plan quota you are willing to spend. This sends
# reasoning effort=max plus prompt_cache_options; the proxy must strip the
# unsupported cache options before the private Codex OAuth request.
export LIVE_E2E_CODEX_GPT56_ADVANCED="0"
export XAI_GROK_BUILD_MODEL="grok-build-0.1"
export XAI_COMPOSER_MODEL="grok-composer-2.5-fast"
export XAI_GROK_MODEL="grok-4.3"
export ZAI_GLM_MODEL="glm-5.1"
export DEEPSEEK_MODEL="deepseek-v4-flash"
